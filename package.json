{
  "name": "payment-order-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "start": "node server.js",
    "mobile": "npm run build && npx cap sync android && npx cap open android",
    "build:apk": "node build-android.js",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "postinstall": "npx puppeteer browsers install chrome && node patch-dependencies.js"
  },
  "dependencies": {
    "@capacitor-community/file-opener": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capgo/capacitor-share-target": "^8.0.35",
    "@google/genai": "latest",
    "adm-zip": "^0.5.10",
    "archiver": "^7.0.0",
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "file-saver": "^2.0.5",
    "form-data": "^4.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.344.0",
    "motion": "^12.38.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "node-windows": "^1.0.0-beta.8",
    "puppeteer": "^22.0.0",
    "qrcode-terminal": "^0.12.0",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-quill": "^2.0.0",
    "recharts": "^2.15.4",
    "web-push": "^3.6.7",
    "whatsapp-web.js": "^1.23.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "@capgo/capacitor-share-target": {
      "@capacitor/core": "$@capacitor/core",
      "@capacitor/android": "$@capacitor/android"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6"
  }
}
